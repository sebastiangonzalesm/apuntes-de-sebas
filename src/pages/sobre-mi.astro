---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import PasameLaVoz from '../components/PasameLaVoz.astro';
import sobre from '../data/sobre.json';

const intereses = sobre.intereses;
---

<Base
  titulo="Sobre mí"
  descripcion="Soy Sebas: abogado por la Universidad del Pacífico, ahora en el MBA, y fundador de Apuntes de Sebas. Esta es la historia detrás del proyecto."
>
  <section class="hero-sobre">
    <div class="contenedor hero-sobre__inner">
      <div class="hero-sobre__avatar" aria-hidden="true">
        <span class="hero-sobre__wave">👋</span>
      </div>
      <div>
        <p class="eyebrow">Sobre mí</p>
        <h1>{sobre.heroTitulo}</h1>
        <p class="hero-sobre__lema">{sobre.heroLema}</p>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor prosa-sobre">
      {sobre.parrafos.map((parrafo) => (<p>{parrafo}</p>))}

      <ul class="intereses">
        {intereses.map((i) => (
          <li class="intereses__item">
            <span aria-hidden="true">{i.emoji}</span> {i.texto}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cta-sobre">
    <div class="contenedor cta-sobre__inner">
      <h2>{sobre.ctaTitulo}</h2>
      <p>{sobre.ctaTexto}</p>
      <PasameLaVoz clase="boton boton--primario" />
      <p class="cta-sobre__links">
        O explora la <a href="/apuntes">biblioteca de apuntes</a> y el
        <a href="/consejos">blog de consejos</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  .hero-sobre {
    background: var(--color-crema);
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }
  .hero-sobre__inner {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 3rem);
  }
  .hero-sobre__avatar {
    flex: none;
    width: clamp(110px, 18vw, 170px);
    height: clamp(110px, 18vw, 170px);
    display: grid;
    place-items: center;
    background: var(--color-crema-tarjeta);
    border-radius: 50%;
    box-shadow: var(--sombra-sm);
  }
  .hero-sobre__wave {
    font-size: clamp(3rem, 7vw, 4rem);
    animation: saludar 2.4s ease-in-out 1;
    transform-origin: 70% 70%;
  }
  @keyframes saludar {
    0%, 60%, 100% { transform: rotate(0deg); }
    10%, 30% { transform: rotate(14deg); }
    20%, 40% { transform: rotate(-8deg); }
  }
  .hero-sobre h1 { margin: 0.3rem 0; }
  .hero-sobre__lema { color: var(--text-secundario); font-size: 1.1rem; margin: 0; }

  .prosa-sobre {
    max-width: 68ch;
    font-size: 1.1rem;
    line-height: 1.75;
  }
  .prosa-sobre p { color: var(--color-tinta); }

  .intereses {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0;
    margin: 2rem 0 0;
  }
  .intereses__item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.1rem;
    background: var(--color-crema);
    border-radius: var(--radio-pildora);
    font-weight: 500;
    font-size: 0.95rem;
  }

  .cta-sobre {
    background: var(--color-tinta);
    color: #fff;
    padding-block: clamp(3rem, 7vw, 4.5rem);
  }
  .cta-sobre__inner { max-width: 620px; text-align: center; }
  .cta-sobre h2 { color: #fff; }
  .cta-sobre p { color: rgba(255, 255, 255, 0.72); }
  .cta-sobre__links { margin-top: 1.5rem; font-size: 0.95rem; }
  .cta-sobre__links a { color: var(--color-naranja); text-decoration: underline; }

  @media (max-width: 560px) {
    .hero-sobre__inner { flex-direction: column; text-align: center; }
  }
</style>
