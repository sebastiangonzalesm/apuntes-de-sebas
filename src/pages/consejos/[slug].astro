---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('consejos', ({ data }) => !data.borrador);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = new Intl.DateTimeFormat('es-PE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Base titulo={post.data.titulo} descripcion={post.data.resumen} tipo="article">
  <article class="post">
    <header class="post__hero">
      <div class="contenedor post__hero-inner">
        <a class="post__volver" href="/consejos">
          <Icon name="arrow-left" size={18} /> Volver a Consejos
        </a>
        <span class="post__emoji" aria-hidden="true">{post.data.emoji}</span>
        <p class="post__cat">{post.data.categoria}</p>
        <h1>{post.data.titulo}</h1>
        <p class="post__fecha">
          <time datetime={post.data.fecha.toISOString()}>{fmt.format(post.data.fecha)}</time>
        </p>
      </div>
    </header>

    <div class="contenedor post__cuerpo">
      <div class="prosa">
        <Content />
      </div>

      <footer class="post__pie">
        <a class="boton boton--contorno" href="/consejos">
          <Icon name="arrow-left" size={18} /> Más consejos
        </a>
      </footer>
    </div>
  </article>
</Base>

<style>
  .post__hero {
    background: var(--color-crema);
    padding-block: clamp(2.5rem, 6vw, 4rem);
    text-align: center;
  }
  .post__volver {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
  }
  .post__emoji { display: block; font-size: 3.2rem; line-height: 1; margin-bottom: 0.5rem; }
  .post__cat {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--brand-acento);
    margin: 0 0 0.4rem;
  }
  .post__hero h1 { max-width: 22ch; margin-inline: auto; }
  .post__fecha { color: var(--text-tenue); font-size: 0.9rem; margin: 0.8rem 0 0; }

  .post__cuerpo { padding-block: var(--espacio-seccion); }
  .prosa {
    max-width: 68ch;
    margin-inline: auto;
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--color-tinta);
  }
  .prosa :global(h2) { margin-top: 2.2rem; }
  .prosa :global(h3) { margin-top: 1.6rem; }
  .prosa :global(a) { text-decoration: underline; }
  .prosa :global(ul),
  .prosa :global(ol) { padding-left: 1.3rem; }
  .prosa :global(li) { margin-bottom: 0.4rem; }
  .prosa :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.8rem 1.4rem;
    border-left: 4px solid var(--color-naranja);
    background: var(--color-crema);
    border-radius: var(--radio-sm);
    color: var(--text-secundario);
  }
  .prosa :global(code) {
    background: var(--color-crema-tarjeta);
    padding: 0.15em 0.4em;
    border-radius: 6px;
    font-size: 0.9em;
  }
  .prosa :global(img) { border-radius: var(--radio-md); margin: 1.5rem auto; }

  .post__pie {
    max-width: 68ch;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid rgba(43, 42, 38, 0.1);
  }
</style>
