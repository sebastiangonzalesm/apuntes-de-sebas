---
/**
 * Icon.astro — íconos de Tabler (https://tabler.io/icons) inline.
 *
 * Mantenibilidad: en vez de una dependencia pesada, guardamos aquí los paths
 * de los íconos que realmente usamos. El campo `icono` de cada curso apunta a
 * una de estas claves. Para agregar un curso con un ícono nuevo, copia el path
 * del ícono de Tabler y agrégalo al mapa `ICONOS` de abajo.
 *
 * Todos los íconos de Tabler son viewBox 0 0 24 24, stroke, sin relleno.
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  'aria-label'?: string;
}

const { name, size = 24, class: className, 'aria-label': ariaLabel } = Astro.props;

